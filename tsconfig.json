{
    "extends": [
        "@windwalker-io/unicorn-next/tsconfig.js.json"
    ],
    "include": [
        "vendor/**/src/Module/**/assets/**/*",
        "resources/assets/src/**/*",
        "src/Module/**/*"
    ],
    "exclude": [
        "node_modules/**/*"
    ],
    "types": [
        "reflect-metadata"
    ],
    "compilerOptions": {
        "types": [
            "vite/client"
        ],
        "paths": {
            "~/*": [
                "./resources/assets/*"
            ],
            "~js/*": [
                "./resources/assets/src/*"
            ],
            "~vendor/*": [
                "./www/assets/vendor/*"
            ],
            "~shopgo": [
                "./resources/assets/src/shopgo/*"
            ]
        }
    }
}
